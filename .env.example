# Database Configuration
# For Local Development:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/airline_db"
#
# For Supabase:
# DATABASE_URL="postgresql://postgres.[project-id]:[password]@db.[project-id].supabase.co:5432/postgres"
#
# For Railway:
# DATABASE_URL="postgresql://[user]:[password]@[host]:[port]/[database]"
#
# For Render:
# DATABASE_URL="postgresql://[user]:[password]@[host]:5432/[database]"
DATABASE_URL="postgresql://user:password@localhost:5432/airline_db"

# Next.js API URL (used by client-side code)
# For local development:
# NEXT_PUBLIC_API_URL="http://localhost:3000"
#
# For Vercel production:
# NEXT_PUBLIC_API_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"
